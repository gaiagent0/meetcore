# ============================================================
# MeetCore - Environment Configuration
# Másold .env néven és töltsd ki a saját értékeiddel!
# ============================================================

# Qualcomm GenieAPIService (helyi NPU, Hexagon v73)
GENIE_BASE_URL=http://127.0.0.1:8912/v1
GENIE_MODEL=llama3.1-8b-8380-qnn2.38
GENIE_TIMEOUT=120

# Ollama (helyi CPU/GPU inference)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_TIMEOUT=300

# NexaAI (NPU ASR + LLM)
NEXA_BASE_URL=http://127.0.0.1:18181/v1
NEXA_TIMEOUT=300
NEXA_ASR_MODEL=NexaAI/parakeet-tdt-0.6b-v3-npu

# Nexa modellek könyvtára — Windows User env var (NEXA_DATADIR)
# Állítsd be a Windows felhasználói környezetben: setx NEXA_DATADIR "E:\models-nexa"
# Ha nincs beállítva, a nexa_manager.py E:\models-nexa-t használ alapértelmezettként
NEXA_DATADIR=E:\models-nexa

# Whisper ASR language
WHISPER_LANGUAGE=hu

# FastAPI backend
BACKEND_PORT=5167

# ============================================================
# Cloud API kulcsokat NE ide írj!
# Az alkalmazás Beállítások oldalán add meg őket — biztonságosan
# a helyi SQLite adatbázisban tárolódnak.
# Támogatott providerek: Claude, Groq, OpenAI, OpenRouter
# ============================================================
